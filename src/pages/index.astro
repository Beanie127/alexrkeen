---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Alex Keen"
	description="The homepage of Alex Keen, an improviser, marketeer and designer based in Sheffield, South Yorkshire, UK.">
	<section id="hero">
		<figure>
			<img
				src="/images/26-profile-dithered.png"
				alt="A dithered image of a man leaning against a brick wall."
			/>
			<figcaption
				>Hi, I'm <a href="/about">Alex</a>. I tell stories and design
				things.</figcaption
			>
		</figure>
		<nav>
			<ul>
				<li>
					<h2 id="works">Works</h2>
					<ul>
						<li><a href="/improv">improv</a></li>
						<li><a href="/writing">writing</a></li>
						<li><a href="/reaching-for-light">film</a></li>
						<li><a href="/games">games</a></li>
						<li>
							<a href="/shoebox">shoebox</a>
						</li>
					</ul>
				</li>
				<li>
					<h2 id="recommendations">Recommendations</h2>
					<ul>
						<li><a href="/blogroll">blogroll</a></li>
						<li><a href="/webrings">webrings</a></li>
						<li><a href="/using">using</a></li>
					</ul>
				</li>
				<li>
					<h2 id="meta">Meta</h2>
					<ul>
						<li><a href="/about">about</a></li>
						<li><a href="/changelog">changelog</a></li>
						<li><a href="/colophon">colophon</a></li>
					</ul>
				</li>
			</ul>
		</nav>
	</section>
</Layout>
<style>
	#hero {
		grid-column: center;
	}

	@media (width > 30rem) {
		#hero {
			padding-block: 3rem;
			display: grid;
			grid-template-columns: repeat(2, 1fr);
		}
	}

	nav ul {
		list-style-type: none;
		padding-inline-start: 0;
	}

	nav ul ul {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	#works {
		margin-block-start: 0;
	}

	figure {
		inline-size: clamp(8rem, 80%, 20rem);
		margin-inline: auto;
	}

	figure img {
		float: unset;
		inline-size: 100%;
	}

	figcaption {
		padding: 0.2lh;
		text-align: center;
		text-wrap: balance;
		font-style: italic;
	}
</style>
