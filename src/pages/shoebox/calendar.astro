---
import Layout from '../../layouts/Layout.astro';
---

<Layout
	title="Calendar"
	description="A magical calendar">
	<style>
		#app {
			display: grid;
			grid-template-columns: repeat(32, 1rem);
			grid-template-rows: repeat(12, 1rem);
			gap: 12px 5px;
			padding: 1rem;
			background: hsl(40 40 26);
			border-radius: 0.5rem;
			box-shadow: inset 0 0 8px 8px hsl(40 60 30);
			margin-inline: auto;
			margin-block: 1rem;
			> div {
				display: grid;
				grid-column: 1 / -1;
				grid-template-columns: subgrid;
			}
		}

		span {
			display: block;
			text-align: center;
			/* font-size: 0.9em; */
			line-height: 0.9;
			color: hsl(60 70 60);
			text-shadow: 0 0 10px hsl(60 30 20);
		}
		.light {
			width: 1rem;
			height: 1rem;
			border-radius: 2rem;
			border: thin solid hsl(40 40 22);
			box-shadow: inset 0 0 2px hsl(0 0 0 / 0.2);
			background: radial-gradient(hsl(40 40 15), hsl(40 40 10));
			transition-property: background;
			transition-duration: 250ms;
			transition-delay: calc(sibling-index() * 50ms);
			&.xmas {
				background: radial-gradient(hsl(0 40 15), hsl(0 40 10));
			}
			&.is-active {
				background: radial-gradient(hsl(40 60 60) 25%, hsl(40 60 45));
				&.xmas {
					background: radial-gradient(hsl(5 70 50) 25%, hsl(5 70 40));
				}
			}
		}
	</style>
