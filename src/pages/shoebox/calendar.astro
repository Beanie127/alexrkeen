	<script is:inline>
		const app = document.querySelector('#app');
		const months = app.querySelectorAll('.month');
		function activateLights() {
			const date = new Date();
			const currentMonth = date.getMonth();
			const currentDay = date.getDate();
			for (let i = 0; i < currentMonth; i++) {
				months[i]
					.querySelectorAll('.light')
					.forEach((light) => light.classList.add('is-active'));
			}
			const currentMonthLights =
				months[currentMonth].querySelectorAll('.light');
			for (let i = 0; i < currentDay; i++) {
				currentMonthLights[i].classList.add('is-active');
			}
		}
		setTimeout(activateLights, 1500);
	</script>
