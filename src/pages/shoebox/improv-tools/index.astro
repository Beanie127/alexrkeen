<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0"
		/>
		<link
			rel="stylesheet"
			href="style.css"
		/>
		<link
			rel="manifest"
			href="/improv-tools/manifest.webmanifest"
		/>
		<link
			rel="apple-touch-icon"
			href="/improv-tools/images/icon-192.png"
		/>
		<title>Alex Keen's Improv Prompt Generator</title>
		<script is:inline>
			navigator.serviceWorker.register('/improv-tools/serviceworker.js');
		</script>
		<style>
			:root {
				--bg-color: hsl(70 11 5);
				--mg-color: hsl(70 11 12);
				--text-color: hsl(40 24 70);
				--h-color: hsl(70 62 20);
				--accent-color: hsl(70 62 20);
			}

			/* font & base colour settings */
			html {
				font-size: clamp(1rem, 0.8rem + 1vi, 1.25rem);
				font-family:
					system-ui,
					-apple-system,
					BlinkMacSystemFont,
					'Segoe UI',
					Roboto,
					Oxygen,
					Ubuntu,
					Cantarell,
					'Open Sans',
					'Helvetica Neue',
					sans-serif;
				line-height: 1.1;
				background-color: var(--bg-color);
				color: var(--text-color);
				box-sizing: border-box;
			}

			body {
				scrollbar-gutter: stable both-edges;
				margin-block: 0;
			}

			/* box-sizing fix */
			*:not(img),
			*:before,
			*:after {
				box-sizing: inherit;
			}

			/* layout */

			main,
			article {
				-webkit-margin-before: clamp(1rem, 2vh, 3rem);
				margin-block-start: clamp(1rem, 2vh, 3rem);
				-webkit-margin-after: 6rem;
				margin-block-end: 6rem;
				margin-inline: auto;
				max-inline-size: 100ch;
				padding: 0rem 1rem;
				font-weight: 400;
				grid-column: 2 / 3;
			}

			.flex {
				margin: 2em auto;
				inline-size: calc(100% - 4rem);
				display: flex;
				flex-wrap: wrap;
				gap: 1ch;
				justify-content: space-around;
				align-items: center;
			}

			.flex.btn-flex {
				flex-basis: 100%;
			}

			/* elements */

			input[type='checkbox'],
			input[type='radio'] {
				position: relative;
				appearance: none;
				inline-size: 1rem;
				aspect-ratio: 1;
				background: var(--mg-color);
				border: thin solid var(--accent-color);
				border-radius: 5px;

				&:checked {
					&::before {
						content: '';
						background: var(--h-color);
						position: absolute;
						inset: 25%;
						inline-size: 50%;
						aspect-ratio: 1;
						border-radius: 2px;
					}
				}
			}
			input[type='radio'] {
				border-radius: 100%;
				transform: translateY(0.25rem);
				margin-inline-end: 0.75ch;
				&:checked::before {
					border-radius: 100%;
				}
			}

			fieldset {
				background: var(--mg-color);
				border: thin dashed var(--h-color);
				border-radius: 8px;
			}

			fieldset legend {
				font-weight: bold;
				padding-inline: 1ch;
			}

			hr {
				border: none;
				border-block-end: thick solid var(--h-color);
				margin-block: 1rem;
			}
			h1 {
				text-align: center;
			}

			button {
				border: thin solid var(--h-color);
				border-radius: 5px;
				padding: 0.5em 1em;
				background: var(--bg-color);
				font-size: 0.7em;
				text-transform: uppercase;
				color: inherit;
			}

			output {
				display: grid;
				margin-block: 1rem;
				border: thin solid var(--accent-color);
				border-radius: 1rem;
				min-block-size: 4lh;
				padding: 1rem;
				place-items: center;
				text-align: center;
				font-size: 1.25em;
				font-weight: 250;
				line-height: 1.1;
				&.output {
					block-size: 4lh;
					overflow-y: scroll;
					& ul {
						list-style: none;
						padding: 0;
						& li:first-of-type {
							font-size: 1.55em;
						}
					}
				}
			}

			.listless {
				list-style-type: none;
				padding-inline-start: 0;
			}

			#player-list {
				font-size: 1.5rem;
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
				justify-content: center;

				li {
					position: relative;
					background: var(--mg-color);
					border-radius: 0.5ch;
					justify-content: space-between;
					align-items: center;
					display: flex;

					label {
						padding-inline: 1.5ch;
					}

					button {
						position: absolute;
						inset-block-start: -1ch;
						inset-inline-end: -1ch;
						border: 0;
						border-radius: 5rem;
						background: var(--mg-color);
						color: red;
						font-size: 0.6rem;
					}
				}
				/* 
    input[type="checkbox"] {
        display: none;
    }
    label:has(input[type="checkbox"]) {
        border: 1px solid var(--accent-color);
        padding: 5px 1ch;
        border-radius: 10px;
    }
    label:has(input:checked) {
        background: var(--h-color);
        color: var(--bg-color);
    }

    label:has(input[type="checkbox"]:not(:checked)) {
        color: gray;
        text-decoration: line-through;
    } */
			}

			/* toggle-tab */

			toggle-tabs {
				[role='tablist'] {
					list-style-type: none;
					display: flex;
					gap: 1ch;
					padding: 0;
					border-block-end: thin solid var(--h-color);
				}

				[role='presentation'] {
					flex: 1 1 0%;
				}

				[role='tab'] {
					padding: 1rem;
					background: var(--mg-color);
					border-radius: 1rem 1rem 0 0;
					text-decoration: none;
					color: currentColor;
					display: block;
					text-align: center;
				}

				[aria-selected='true'] {
					background: var(--h-color);
					/* color: var(--bg-color); */
				}
			}
		</style>
		<style is:inline>
			[type='checkbox'] {
				display: none;
			}
			label:has([type='checkbox']) {
				border: 1px solid var(--accent-color);
				padding: 5px 1ch;
				border-radius: 10px;
			}
			label:has([type='checkbox']:checked) {
				background: var(--h-color);
				/* color: var(--bg-color); */
			}

			label:has([type='checkbox']:not(:checked)) {
				color: gray;
				text-decoration: line-through;
			}
		</style>
	</head>

	<body>
		<main>
			<!-- <div class="wrapper"> -->
			<h1>Improv Tools</h1>
			<toggle-tabs>
				<ul>
					<li><a href="#players">Players</a></li>
					<li><a href="#games">Games</a></li>
					<li><a href="#suggestions">Suggestions</a></li>
				</ul>
				<div id="players">
					<form id="add-player">
						<output
							id="player-output"
							class="output">
							<ul></ul>
						</output>
						<div
							class="flex"
							id="controls">
							<button
								type="button"
								id="pick-player"
								>Pick a player</button
							>
							<button
								type="button"
								id="reset-checkboxes"
								>Reset checkboxes</button
							>
							<button
								type="button"
								id="remove-all-players"
								>Remove all players</button
							>
						</div>
						<fieldset class="flex">
							<legend>Add a new player</legend>
							<label for="player"
								>Name:
								<input
									type="text"
									name="player"
									id="player"
								/>
							</label>
							<button type="submit">Add player</button>
						</fieldset>
					</form>
					<ul
						id="player-list"
						class="listless">
					</ul>
				</div>
				<div id="games">
					<form id="game-generator">
						<output>
							<ul
								id="current-game"
								class="listless"
								hidden>
								<li>
									<strong>Name:</strong>
									<span id="game-name"></span>
								</li>
								<li>
									<strong>Players:</strong>
									<span id="game-player-count"></span>
								</li>
								<li id="game-description"></li>
							</ul>
						</output>
						<div class="flex">
							<button type="submit">Get a game</button>
							<button
								type="button"
								id="game-reset"
								>Reset</button
							>
						</div>
						<fieldset class="flex">
							<legend>Difficulties</legend>
							<label
								><input
									type="checkbox"
									name="difficulty"
									value="easy"
									checked
								/>Easy</label
							>
							<label
								><input
									type="checkbox"
									name="difficulty"
									value="medium"
									checked
								/>Medium</label
							>
							<label
								><input
									type="checkbox"
									name="difficulty"
									value="hard"
									checked
								/>Hard</label
							>
						</fieldset>
						<fieldset class="flex">
							<legend>Players</legend>
							<label
								><input
									type="checkbox"
									name="playerCount"
									value="2"
									checked
								/>2</label
							>
							<label
								><input
									type="checkbox"
									name="playerCount"
									value="3"
									checked
								/>3</label
							>
							<label
								><input
									type="checkbox"
									name="playerCount"
									value="4"
									checked
								/>4</label
							>
							<label
								><input
									type="checkbox"
									name="playerCount"
									value="6"
								/>6</label
							>
						</fieldset>
						<fieldset class="flex">
							<legend>Categories</legend>
							<label
								><input
									type="checkbox"
									name="tag"
									value="physical"
									checked
								/>Physical</label
							>
							<label
								><input
									type="checkbox"
									name="tag"
									value="talking heads"
									checked
								/>Talking Heads</label
							>
							<label
								><input
									type="checkbox"
									name="tag"
									value="guessing"
									checked
								/>Guessing Game</label
							>
							<label
								><input
									type="checkbox"
									name="tag"
									value="mime"
									checked
								/>Mime</label
							>
							<label
								><input
									type="checkbox"
									name="tag"
									value="scene"
									checked
								/>Scene</label
							>
						</fieldset>
					</form>
				</div>
				<div id="suggestions">
					<form id="prompt-generator">
						<output
							id="suggestion-output"
							class="output">
							<ul></ul>
						</output>
						<div class="flex">
							<button type="submit">Get a suggestion</button>
						</div>
						<fieldset class="flex">
							<legend>Suggestion type</legend>
							<label for="any"
								><input
									type="radio"
									id="any"
									name="type"
									value="any"
									checked
								/>any</label
							>
							<label for="job"
								><input
									type="radio"
									id="job"
									name="type"
									value="job"
								/>job</label
							>
							<label for="activity"
								><input
									type="radio"
									id="activity"
									name="type"
									value="activity"
								/>activity</label
							>
							<label for="event"
								><input
									type="radio"
									id="event"
									name="type"
									value="event"
								/>event</label
							>
							<label for="object"
								><input
									type="radio"
									id="object"
									name="type"
									value="object"
								/>object</label
							>
							<label for="emotion"
								><input
									type="radio"
									id="emotion"
									name="type"
									value="emotion"
								/>emotion</label
							>
							<label for="relationship"
								><input
									type="radio"
									id="relationship"
									name="type"
									value="relationship"
								/>relationship</label
							>
							<label for="location"
								><input
									type="radio"
									id="location"
									name="type"
									value="location"
								/>location</label
							>
							<label for="story"
								><input
									type="radio"
									id="story"
									name="type"
									value="story"
								/>story</label
							>
						</fieldset>
					</form>
				</div>
			</toggle-tabs>
		</main>

		<script
			type="module"
			src="/js/toggle-tabs.js"
		></script>
		<script
			type="module"
			src="/improv-tools/suggestions.js"
		></script>
		<script
			type="module"
			src="/improv-tools/games.js"
		></script>
		<script
			type="module"
			src="/improv-tools/players.js"
		></script>
	</body>
</html>
